                                                                                                </constraints>
                                                                                                <string key="text">#!/usr/bin/env python3
"""
iMessage Export Script for ContactSync
Run this on your Mac to export iMessage history.
Requires Full Disk Access for Terminal in System Settings &gt; Privacy &amp; Security.
"""
import sqlite3
import csv
import os
from datetime import datetime, timedelta

DB_PATH = os.path.expanduser("~/Library/Messages/chat.db")
OUTPUT_FILE = os.path.expanduser("~/Desktop/imessage_export.csv")
APPLE_EPOCH = datetime(2001, 1, 1)

def export_imessages(days_back=90):
    if not os.path.exists(DB_PATH):
        print("Error: chat.db not found. Make sure you're running this on a Mac.")
        return

    try:
        conn = sqlite3.connect(DB_PATH)
        cursor = conn.cursor()

        cutoff = datetime.now() - timedelta(days=days_back)
        cutoff_ticks = int((cutoff - APPLE_EPOCH).total_seconds() * 1_000_000_000)

        query = """
            SELECT
                h.id AS phone_number,
                m.date AS date_ticks,
                m.is_from_me
            FROM message m
            JOIN chat_message_join cmj ON m.ROWID = cmj.message_id
            JOIN chat_handle_join chj ON cmj.chat_id = chj.chat_id
            JOIN handle h ON chj.handle_id = h.ROWID
            WHERE m.date &gt; ?
            ORDER BY m.date DESC
        """

        cursor.execute(query, (cutoff_ticks,))
        rows = cursor.fetchall()

        with open(OUTPUT_FILE, "w", newline="") as f:
            writer = csv.writer(f)
            writer.writerow(["phone_number", "date", "is_from_me"])
            for phone, date_ticks, is_from_me in rows:
                ts = APPLE_EPOCH + timedelta(seconds=date_ticks / 1_000_000_000)
                writer.writerow([phone, ts.isoformat(), is_from_me])

        print(f"Exported {len(rows)} messages to {OUTPUT_FILE}")
        print(f"Upload this file to ContactSync to log your iMessage interactions.")
        conn.close()

    except sqlite3.OperationalError as e:
        if "unable to open" in str(e).lower():
            print("Permission denied. Grant Full Disk Access to Terminal:")
            print("  System Settings &gt; Privacy &amp; Security &gt; Full Disk Access")
        else:
            print(f"Database error: {e}")

if __name__ == "__main__":
    export_imessages()
</string>
